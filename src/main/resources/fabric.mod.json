{
	"schemaVersion": 1,
	"id": "hold-to-sprint",
	"version": "${version}",
	"name": "Hold to Sprint",
	"description": "A mod that makes it so that you have to hold to sprint. If you let go, you stop sprinting.",
	"authors": [
		"infloat"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/hold-to-sprint",
		"sources": "https://github.com/ruhan-p/holdtosprint"
	},
	"license": "CC0-1.0",
	"icon": "assets/hold-to-sprint/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"infloat.holdtosprint.HoldToSprint"
		]
	},
	"mixins": [
		"hold-to-sprint.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}